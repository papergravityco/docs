{
  "$schema": "https://mintlify.com/schema.json",
  "theme": "mint",
  "name": "PaperGravity Docs",
  "domain": "docs.papergravity.com",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": ["index"],
    "products": [
      {
        "product": "ParkSig",
        "icon": "sign-hanging",
        "groups": [
          {
            "group": "ParkSig",
            "root": "parksig/index",
            "pages": []
          },
          {
            "group": "Guide",
            "pages": ["parksig/getting-started", "parksig/api-reference"]
          },
          {
            "group": "Support",
            "pages": ["parksig/faq"]
          }
        ]
      },
      {
        "product": "Pixlayo",
        "icon": "images",
        "groups": [
          {
            "group": "Pixlayo",
            "root": "pixlayo/index",
            "pages": []
          },
          {
            "group": "Overview",
            "pages": ["pixlayo/overview", "pixlayo/integrations"]
          },
          {
            "group": "Troubleshooting",
            "pages": ["pixlayo/troubleshooting"]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@papergravity.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.papergravity.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/papergravity",
      "github": "https://github.com/papergravity"
    }
  }
}
